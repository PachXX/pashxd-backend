# ─── PashxD backend configuration ────────────────────────────────────────
# Copy to .env for local dev. In production these are split between
# Secret Manager (secrets) and Cloud Run env vars (non-secrets) — see DEPLOYMENT.md.

# ── Secrets (→ Secret Manager in production) ──
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@pashx.com
ADMIN_PASSWORD=change-me
SENDGRID_API_KEY=SG.xxxxxxxx
CORS_ORIGINS=http://localhost:5173,https://pashx.com

# ── Non-secret config (→ Cloud Run env vars in production) ──
DB_NAME=pashxd
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
FRONTEND_URL=https://pashx.com
ADMIN_URL=https://admin.pashx.com
SENDGRID_FROM_EMAIL=info@pashx.com
SENDGRID_FROM_NAME=PashxD

# ── Runtime / observability ──
LOG_FORMAT=text          # 'json' on Cloud Run, 'text' locally
LOG_LEVEL=INFO
# GOOGLE_CLOUD_PROJECT is injected automatically on Cloud Run.
# FIREBASE_PROJECT_ID=pashxd-prod   # only if using Firebase Auth
