# ── PashxD API environment ───────────────────────────────────────────
# Production values live in Google Secret Manager and are injected into
# Cloud Run via --set-secrets / --set-env-vars (see scripts/deploy.sh).
# This file documents every variable; copy to .env for local dev only.

# Database (REQUIRED in production — stored in Secret Manager)
MONGO_URL=mongodb://localhost:27017
DB_NAME=pashxd

# Auth (REQUIRED in production — stored in Secret Manager)
JWT_SECRET=change-me-locally
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Admin bootstrap (optional; if unset in production, no admin is seeded)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# CORS / URLs
FRONTEND_URL=https://pashx.com
ADMIN_URL=https://admin.pashx.com
CORS_ORIGINS=
BACKEND_URL=http://localhost:8000

# Email (SendGrid — API key stored in Secret Manager in production)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@pashx.com
SENDGRID_FROM_NAME=PashxD
OUTREACH_CC=

# Firebase / Google Cloud (optional locally; automatic on Cloud Run)
# Setting FIREBASE_PROJECT_ID (or GOOGLE_CLOUD_PROJECT) enables the
# Firebase Admin SDK, which then authenticates via Application Default
# Credentials.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Logging
LOG_LEVEL=INFO
# LOG_FORMAT=json forces Cloud Logging JSON format locally
LOG_FORMAT=
