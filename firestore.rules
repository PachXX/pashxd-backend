rules_version = '2';

// MongoDB Atlas remains the system of record for this backend; all
// Firestore access goes through the Admin SDK on Cloud Run, which
// bypasses these rules. Client access is therefore denied by default —
// open specific paths deliberately if the frontend ever reads Firestore
// directly.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    // Admin users (custom claim role=admin) may read app data client-side.
    match /{document=**} {
      allow read: if isAdmin();
      allow write: if false; // writes only via the backend (Admin SDK)
    }
  }
}
