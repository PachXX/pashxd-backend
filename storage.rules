rules_version = '2';

// Uploads flow through the backend (Admin SDK, bypasses rules).
// Clients: admins may read; nobody may write directly.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if false;
    }
  }
}
