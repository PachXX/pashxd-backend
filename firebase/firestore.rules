rules_version = '2';

// PashxD stores its application data in MongoDB Atlas, not Firestore.
// Firebase is provisioned for Authentication (and optionally Storage). These
// rules therefore DENY all direct client access to Firestore by default — the
// backend service account bypasses rules via the Admin SDK when needed.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
